{
  "compilerOptions": {
    "baseUrl": ".",
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ESNext",
    "allowJs": true,
    "noImplicitAny": true,
    "moduleResolution": "node",
    "importHelpers": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "strict": true,
    "lib": [
      "DOM",
      "ESNext"
    ],
    "types": [
      "node"
    ],
    "paths": {
      "module_bindings/*": [
        "src/module_bindings/*"
      ]
    }
  },
  "include": [
    "src/**/*.ts"
  ]
}
